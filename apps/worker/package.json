{
  "name": "funbutton-worker",
  "version": "0.1.0",
  "private": true,
  "description": "FunButton.ai Cloudflare Worker — licensing, AI routing, metering, Stripe.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy": "wrangler deploy --env production",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "mint-test-license": "tsx scripts/mint-test-license.ts",
    "d1:migrate:local": "wrangler d1 migrations apply funbutton-prod --local",
    "d1:migrate:remote": "wrangler d1 migrations apply funbutton-prod --remote",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^25.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "wrangler": "^4.74.0"
  }
}
